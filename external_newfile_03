#include <iostream>
#include <vector>
#include <clocale>

using namespace std;

struct Tree
{
    int data;
    Tree* left;
    Tree* right;
};

Tree* createTree(int val)
{
    Tree* newTree = new Tree;
    newTree->data = val;
    newTree->left = nullptr;
    newTree->right = nullptr;
    return newTree;
}

Tree* insertTree(Tree* root, int val)
{
    if (root == nullptr)
    {
        return createTree(val);
    }
    if (val < root->data)
    {
        root->left = insertTree(root->left, val);
    }
    else if (val > root->data)
    {
        root->right = insertTree(root->right, val);
    }
    return root;
}


void DoTraverseAndInsert(Tree* root2, Tree*& root1)
{
    if (root2 == nullptr) return;
    DoTraverseAndInsert(root2->left, root1);
    root1 = insertTree(root1, root2->data);
    DoTraverseAndInsert(root2->right, root1);
}

Tree* combineTrees(Tree* root1, Tree* root2)
{
    DoTraverseAndInsert(root2, root1);
    return root1;
}

Tree* TreeFromVector(vector<int>& vec)
{
    Tree* root = nullptr;
    for (int val : vec)
    {
        root = insertTree(root, val);
    }
    return root;
}

void printTree(Tree* root)
{
    if (root == nullptr) return;
    printTree(root->left);
    cout << root->data << " ";
    printTree(root->right);
}

int main()
{
    setlocale(LC_ALL, "Russian");

    vector<int> values1 = { 8, 3, 10, 1, 6, 14, 4, 7, 13 };
    vector<int> values2 = { 15, 5, 12, 9, 20, 2, 11 };

    Tree* root1 = TreeFromVector(values1);
    Tree* root2 = TreeFromVector(values2);

    cout << "Первое дерево: ";
    printTree(root1);
    std::cout << std::endl;

    cout << "Второе дерево: ";
    printTree(root2);
    cout << std::endl;

    root1 = combineTrees(root1, root2);

    cout << "Объединённое дерево: ";
    printTree(root1);
    cout << std::endl;

    return 0;
}
