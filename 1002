//нахождение суммы
int SummRing(List2* beg)
{
	if (beg == NULL)
		return 0;
	int sm = 0;
	List2* tmp = beg;
	do
	{
		sm += tmp->info;
		tmp = tmp->next;
	} while (tmp != beg);
	return sm;
}

