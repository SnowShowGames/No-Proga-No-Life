//сумма эл. двух списков, из первого берём четные эл. из вторного нечётные
int DoubleSummRing(List2* chetn, List2* nechetn)
{
	List2* tmp1 = chetn;
	int sm = 0;
	do
	{
		if (tmp1->info % 2 == 0)
		{
			sm += tmp1->info;
		}
		tmp1 = tmp1->next;
	} while (tmp1 != chetn);
	List2* tmp2 = nechetn;
	do
	{
		if (tmp2->info % 2 != 0)
		{
			sm += tmp2->info;
		}
		tmp2 = tmp2->next;
	} while (tmp2 != nechetn);
	return sm;
}

