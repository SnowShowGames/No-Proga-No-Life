bool ListDown(List2* beg)
{
	if (beg == NULL)
	{
		return 1;
	}
	List2* tmp = beg;
	while (tmp->next != NULL)
	{
		tmp = tmp->next;
	}
	return ListDown(tmp); //tmp->pred;
}

