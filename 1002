//проверка на упорядоченность через рекурсивный алгоритм
bool BegToEndCursed(List2* beg)
{
	if (beg == NULL)
	{
		return true;
	}
	if (beg->pred == NULL)
	{
		return true;
	}
	if (beg->info > beg->pred->info)
	{
		return false;
	}
	return beg->pred;
}

