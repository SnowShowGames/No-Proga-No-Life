//==================== ЗАДАЧА 1 ====================
struct List {
    int data;
    List* next;
};

struct List1 {
    int data;
    List1* next;
};

List* createList(int val) {
    List* newList = new List;
    newList->data = val;
    newList->next = NULL;
    return newList;
}

List1* createList1(int val) {
    List1* newList = new List1;
    newList->data = val;
    newList->next = NULL;
    return newList;
}

void appEnd(List*& head, int val) {
    List* newList = createList(val);
    if (head == nullptr) {
        head = newList;
    }
    else {
        List* tmp = head;
        while (tmp->next != nullptr) {
            tmp = tmp->next;
        }
        tmp->next = newList;
    }
}

void appEnd1(List1*& head, int val) {
    List1* newList1 = createList1(val);
    if (head == nullptr) {
        head = newList1;
    }
    else {
        List1* tmp = head;
        while (tmp->next != nullptr) {
            tmp = tmp->next;
        }
        tmp->next = newList1;
    }
}

void printList(List* head) {
    List* tmp = head;
    while (tmp != nullptr) {
        cout << tmp->data << " ";
        tmp = tmp->next;
    }
}

void printList1(List1* head) {
    List1* tmp = head;
    while (tmp != nullptr) {
        cout << tmp->data << " ";
        tmp = tmp->next;
    }
}

void lastToFront(List*& head) {
    if (head == nullptr || head->next == nullptr) return;
    List* prev = nullptr;
    List* last = head;
    while (last->next != nullptr) {
        prev = last;
        last = last->next;
    }
    prev->next = nullptr;
    last->next = head;
    head = last;
}

void insertToFirstE(List*& head, int E, List1* L1) {
    if (head == nullptr || L1 == nullptr) return;

    List* tmp = head;
    List* target = nullptr;
    while (tmp != nullptr) {
        if (tmp->data == E) {
            target = tmp;
            break;
        }
        tmp = tmp->next;
    }

    if (target == nullptr) return;

    List* afterE = target->next;
    List1* tmp1 = L1;
    List* last = target;

    while (tmp1 != nullptr) {
        List* newList = createList(tmp1->data);
        last->next = newList;
        last = newList;
        tmp1 = tmp1->next;
    }
    last->next = afterE;
}

void deleteList(List* head) {
    while (head) {
        List* tmp = head;
        head = head->next;
        delete tmp;
    }
}

void deleteList1(List1* head) {
    while (head) {
        List1* tmp = head;
        head = head->next;
        delete tmp;
    }
}

