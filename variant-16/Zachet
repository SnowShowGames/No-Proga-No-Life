int sumOfDivisors(int n) {
    if (n <= 1) return 0;
    int sum = 1;
    for (int i = 2; i * i <= n; i++) {
        if (n % i == 0) {
            sum += i;
            if (i != n / i) sum += n / i;
        }
    }
    return sum;
}

bool areFriendly(int a, int b) {
    if (a == b) return false;
    return (sumOfDivisors(a) == b && sumOfDivisors(b) == a);
}

void moveFriendlyToFront(vector<int>& arr) {
    if (arr.size() < 2) return;

    int firstIdx = -1, secondIdx = -1;

    for (size_t i = 0; i < arr.size(); i++) {
        for (size_t j = i + 1; j < arr.size(); j++) {
            if (areFriendly(arr[i], arr[j])) {
                firstIdx = i;
                secondIdx = j;
                break;
            }
        }
        if (firstIdx != -1) break;
    }

    if (firstIdx == -1) return;

    int val1 = arr[firstIdx];
    int val2 = arr[secondIdx];

    vector<int> remaining;
    for (size_t i = 0; i < arr.size(); i++) {
        if (i != firstIdx && i != secondIdx) {
            remaining.push_back(arr[i]);
        }
    }

    arr.clear();
    arr.push_back(val1);
    arr.push_back(val2);
    for (size_t i = 0; i < remaining.size(); i++) {
        arr.push_back(remaining[i]);
    }
}

