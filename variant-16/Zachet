void task4() {
    cout << "\n========== ЗАДАЧА 4 ==========\n";
    cout << "Сравнить два текстовых файла\n\n";

    const char* fname = "f.txt";
    const char* gname = "g.txt";

    //тестовые файлы
    ofstream fout(fname);
    fout << "Hello world!\n";
    fout << "This is line 2\n";
    fout << "Line number 3";
    fout.close();

    ofstream gout(gname);
    gout << "Hello world!\n";
    gout << "This is line 2\n";
    gout << "Line number 4";
    gout.close();

    ifstream f1(fname);
    ifstream f2(gname);

    char sym1, sym2;
    int lineNum = 1;
    int pos = 1;
    bool identical = true;

    while (f1.get(sym1) && f2.get(sym2)) {
        if (sym1 != sym2) {
            identical = false;
            break;
        }
        if (sym1 == '\n') {
            lineNum++;
            pos = 1;
        }
        else {
            pos++;
        }
    }

    if (identical) {
        char dummy;
        if (f1.get(dummy) || f2.get(dummy)) {
            identical = false;
        }
    }

    if (!identical) {
        cout << "Файлы отличаются в строке " << lineNum << ", позиция " << pos << "\n";
    }
    else {
        cout << "Файлы совпадают\n";
    }

    f1.close();
    f2.close();
}

