struct Tree {
    int data;
    Tree* left;
    Tree* right;
};

Tree* createTree(int val) {
    Tree* newTree = new Tree;
    newTree->data = val;
    newTree->left = nullptr;
    newTree->right = nullptr;
    return newTree;
}

Tree* insertTree(Tree* root, int val) {
    if (root == nullptr) return createTree(val);
    if (val < root->data) root->left = insertTree(root->left, val);
    else if (val > root->data) root->right = insertTree(root->right, val);
    return root;
}

void traverseAndInsert(Tree* root2, Tree*& root1) {
    if (root2 == nullptr) return;
    traverseAndInsert(root2->left, root1);
    root1 = insertTree(root1, root2->data);
    traverseAndInsert(root2->right, root1);
}

Tree* combineTrees(Tree* root1, Tree* root2) {
    traverseAndInsert(root2, root1);
    return root1;
}

void printTree(Tree* root) {
    if (root == nullptr) return;
    printTree(root->left);
    cout << root->data << " ";
    printTree(root->right);
}

void deleteTree(Tree* root) {
    if (root == nullptr) return;
    deleteTree(root->left);
    deleteTree(root->right);
    delete root;
}

