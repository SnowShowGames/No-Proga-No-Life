    int maxVal = seq[0], minVal = seq[0];
    for (int i = 0; i < seq.size(); i++) {
        if (seq[i] == 0) break;
        if (seq[i] > maxVal) maxVal = seq[i];
        if (seq[i] < minVal) minVal = seq[i];
    }

    cout << "Наибольшее: " << maxVal << ", Наименьшее: " << minVal << "\n";
    cout << "Числа между ними в обратном порядке: ";

    for (int i = seq.size() - 2; i >= 0; i--) {
        if (seq[i] == 0) continue;
        if (seq[i] > minVal && seq[i] < maxVal) {
            cout << seq[i] << " ";
        }
    }
    cout << "\n";
}

