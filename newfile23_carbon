#include <vector>
#include <iostream>

using namespace std;


int maxVector(vector <int> x)
{
	int max=x[0];
	for (auto i : x)
	{
	if (max < i) max = i;
}
	return max;
}

int SumVector(vector <int> x)
{
	int sm=0;
	for (auto i : x)
	{
		sm += i;
	}
	return sm;
}

