#include <iostream>
#include <vector>

using namespace std;

int sumOfDivisors(int n) {
    if (n <= 1) return 0;

    int sum = 1;
    for (int i = 2; i * i <= n; i++) {
        if (n % i == 0) {
            sum += i;
            if (i != n / i) {
                sum += n / i;
            }
        }
    }
    return sum;
}

bool areFriendly(int a, int b) {
    if (a == b) return false;
    return (sumOfDivisors(a) == b && sumOfDivisors(b) == a);
}

void MoveToFront(vector<int>& arr) {
    if (arr.size() < 2) return;

    vector<int>::iterator firstIt = arr.end();
    vector<int>::iterator secondIt = arr.end();

    for (vector<int>::iterator i = arr.begin(); i != arr.end(); ++i) {
        vector<int>::iterator j = i;
        ++j;
        for (; j != arr.end(); ++j) {
            if (areFriendly(*i, *j)) {
                firstIt = i;
                secondIt = j;
                break;
            }
        }
        if (firstIt != arr.end()) break;
    }

    if (firstIt == arr.end()) return;

    int val1 = *firstIt;
    int val2 = *secondIt;

    vector<int> rmng;
    for (vector<int>::iterator it = arr.begin(); it != arr.end(); ++it) {
        if (it != firstIt && it != secondIt) {
            rmng.push_back(*it);
        }
    }

    arr.clear();
    arr.push_back(val1);
    arr.push_back(val2);
    for (vector<int>::iterator it = rmng.begin(); it != rmng.end(); ++it) {
        arr.push_back(*it);
    }
}

void printArray(const vector<int>& arr) {
    for (vector<int>::const_iterator it = arr.begin(); it != arr.end(); ++it) {
        cout << *it << " ";
    }
    cout << endl;
}

int main() {
    vector<int> arr = { 82,100,2,6,52,65,4 };

    cout << "Исходный массив: ";
    printArray(arr);

    MoveToFront(arr);
    cout << "После перемещения: ";
    printArray(arr);

    return 0;
}
