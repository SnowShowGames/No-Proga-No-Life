//двухсвязный список
List2* make_rist()
{
	List2* ring = new List2;
	int x; cout << "Vvedite elem: " << endl;
	cin >> x; ring->info = x;//эл-т в список
	List2* tmp = ring;//указат. на голову
	cout << "Vvedite elem: " << " ";
	while (x) //вводим пока не 0
	{
		List2* l = new List2;//указатель на след. узел
		l->info = x;//новый след. эл. списка
		l->pred = tmp;//пред. на предыдущ.
		tmp->next = l; tmp = l;
			cin >> x;
	}
	//свернёт список в кольцо 
	tmp->next = ring;
	ring->pred = tmp;
	return ring;
}

//вывод эл-т кольц. списка 1
void PrintRing(List2* ring)
{
	List2* tmp = ring;
	do
	{
		tmp = tmp->next;
		cout << tmp->info << " ";
	} while (tmp != ring->pred);
}

