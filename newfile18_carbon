//проверка на сииметричность
bool simmLIst(List2* beg)
{
	//if (beg != NULL) return false;
	List2* end = beg;
	while (end->next != NULL)
	{
		end = end->next;
	}
	while (beg != NULL)
	{
		if (beg->info != end->info)
		{
			return false;
		}
		beg = beg->next;
		end = end->pred;
	}
	return true;
}

