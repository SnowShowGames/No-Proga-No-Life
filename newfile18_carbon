//сумма эл. двух списков, из первого берём четные эл. из вторного нечётные
int DoubleSummRing(List2* chetn, List2* nechetn)
{
	List2* tmp1 = chetn;
	int sm = 0;
	do
	{
		tmp1 = tmp1->next;
		if (tmp1->info % 2 == 0)
		{
			sm += tmp1->info;
		}
	} while (tmp1->next != chetn);
	List2* tmp2 = nechetn;
	do
	{
		tmp2 = tmp2->next;
		if (tmp2->info % 2 != 0)
		{
			sm += tmp2->info;
		}
	} while (tmp2->next != nechetn);
	return sm;
}

