#include <iostream>
#include <vector>
#include <clocale>

struct Tree
{
    int data;
    Tree* left;
    Tree* right;
};

Tree* createTree(int val)
{
    Tree* newTree = new Tree;
    newTree->data = val;
    newTree->left = nullptr;
    newTree->right = nullptr;
    return newTree;
}

Tree* insertTree(Tree* root, int val)
{
    if (root == nullptr)
    {
        return createTree(val);
    }
    if (val < root->data)
    {
        root->left = insertTree(root->left, val);
    }
    else if (val > root->data)
    {
        root->right = insertTree(root->right, val);
    }
    return root;
}

// Функция для обхода второго дерева и вставки его элементов в первое
void traverseAndInsert(Tree* root2, Tree*& root1)
{
    if (root2 == nullptr) return;
    traverseAndInsert(root2->left, root1);
    root1 = insertTree(root1, root2->data);
    traverseAndInsert(root2->right, root1);
}

// Функция объединения двух деревьев
Tree* combineTrees(Tree* root1, Tree* root2)
{
    traverseAndInsert(root2, root1);
    return root1;
}

// Создание дерева из вектора
Tree* createTreeFromVector(const std::vector<int>& vec)
{
    Tree* root = nullptr;
    for (int val : vec)
    {
        root = insertTree(root, val);
    }
    return root;
}

// Вывод дерева (симметричный обход)
void printTree(Tree* root)
{
    if (root == nullptr) return;
    printTree(root->left);
    std::cout << root->data << " ";
    printTree(root->right);
}

// Очистка памяти
void deleteTree(Tree* root)
{
    if (root == nullptr) return;
    deleteTree(root->left);
    deleteTree(root->right);
    delete root;
}

int main()
{
    setlocale(LC_ALL, "Russian");

    // Создаём векторы с готовыми значениями
    std::vector<int> values1 = { 8, 3, 10, 1, 6, 14, 4, 7, 13 };
    std::vector<int> values2 = { 15, 5, 12, 9, 20, 2, 11 };

    // Строим деревья из векторов
    Tree* root1 = createTreeFromVector(values1);
    Tree* root2 = createTreeFromVector(values2);

    std::cout << "Первое дерево: ";
    printTree(root1);
    std::cout << std::endl;

    std::cout << "Второе дерево: ";
    printTree(root2);
    std::cout << std::endl;

    // Объединяем деревья
    root1 = combineTrees(root1, root2);

    std::cout << "Объединённое дерево: ";
    printTree(root1);
    std::cout << std::endl;

    // Очищаем память
    deleteTree(root2); // удаляем оставшиеся узлы второго дерева
    deleteTree(root1); // удаляем объединённое дерево

    return 0;
}