#include <iostream>

using namespace std;

struct ListNode {
	int data;
	ListNode* right;
	ListNode* left;
};

struct Tree {
	int info;
	Tree* left;
	Tree* right;
};

void Add(Tree* root, int data)
{
	if (data < root->info)
		if (root->left == NULL) {
			Tree* q;
				q = new(Tree);
			q->info = data;
			q->left = NULL;
			q->right = NULL;
			root->left = q;
		}
		else Add(root->left, data);
	else
		if (root->right == NULL) {
			Tree* q;
			q = new(Tree);
			q->info = data;
			q->left = NULL;
			q->right = NULL;
			root->right = q;
		}
		else Add(root->right, data);
}

Tree* ListToTree(ListNode* head)
{
	Tree* t = new Tree;
	t->left = 0; t->right = 0;
	t->info = head->data;
	ListNode* tmp = head->right;
	while (tmp) {
		Add(t, tmp->data);
		tmp = tmp->right;
	}

	return t;
}

Tree* deltree(Tree* root)
{
	root->left = deltree(root->left);
	root->right = deltree(root->right);

	if (root->info % 2 == 0)
	{
		delete root; return nullptr;
	}
	return root;
}

void PrintTree(Tree* root)
{
	PrintTree(root->left);
	cout << root->info << " ";
	PrintTree(root->right);
}

