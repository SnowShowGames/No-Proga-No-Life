#include <iostream>
#include <vector>

int sumOfDivisors(int n) {
    if (n <= 1) return 0;
    
    int sum = 1;
    for (int i = 2; i * i <= n; i++) {
        if (n % i == 0) {
            sum += i;
            if (i != n / i) {
                sum += n / i;
            }
        }
    }
    return sum;
}

bool areFriendly(int a, int b) {
    if (a == b) return false;
    return (sumOfDivisors(a) == b && sumOfDivisors(b) == a);
}

void moveFriendlyPairToFrontInPlace(std::vector<int>& arr) {
    int n = arr.size();
    int firstIndex = -1, secondIndex = -1;
    
    // Поиск первой пары дружественных чисел
    for (int i = 0; i < n && firstIndex == -1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (areFriendly(arr[i], arr[j])) {
                firstIndex = i;
                secondIndex = j;
                break;
            }
        }
    }
    
    if (firstIndex == -1) return;
    
    // Сохраняем значения пары
    int val1 = arr[firstIndex];
    int val2 = arr[secondIndex];
    
    // Сдвигаем элементы, чтобы освободить место в начале
    // Удаляем элементы с индексов firstIndex и secondIndex
    // и сдвигаем остальные влево
    
    // Создаем временный массив для элементов, которые не входят в пару
    std::vector<int> remaining;
    for (int i = 0; i < n; i++) {
        if (i != firstIndex && i != secondIndex) {
            remaining.push_back(arr[i]);
        }
    }
    
    // Собираем новый массив: сначала пара, затем остальные
    arr.clear();
    arr.push_back(val1);
    arr.push_back(val2);
    for (int i = 0; i < remaining.size(); i++) {
        arr.push_back(remaining[i]);
    }
}

void printArray(const std::vector<int>& arr) {
    for (int i = 0; i < arr.size(); i++) {
        std::cout << arr[i] << " ";
    }
    std::cout << std::endl;
}

int main() {
    std::vector<int> arr;
    arr.push_back(10);
    arr.push_back(284);
    arr.push_back(15);
    arr.push_back(220);
    arr.push_back(30);
    arr.push_back(50);
    
    std::cout << "Исходный массив: ";
    printArray(arr);
    
    moveFriendlyPairToFrontInPlace(arr);
    std::cout << "После перемещения: ";
    printArray(arr);
    
    return 0;
}