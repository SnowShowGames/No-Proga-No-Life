map <char, int> KolSymb(string s)
{
map<char, int> w;
for (char c:s)
w[c]++; //w[c]=w[c]+1;
return w;
}
int main()
{
	setlocale(LC_ALL, "Rus");
	vector <string> words = { "ПАРК","КАРП","СОМ","МОС","ДЕНЬ" };
	map <map<char, int>, int> s;
	for (const string& word : words)
		s[KolSymb(word)]++;
	cout << "Слова без ..." << endl;
for (const string & word : words)
{
	if (s[KolSymb(word)] == 1)
		cout << word << endl;
}
return 0;
}
