int main() {
	setlocale(LC_ALL, "RUSSIAN");
	cout << "Укажите имя файла: ";
	const string FName = "worker.bin";
	Worker teacher;
	strcpy_s(teacher.name, "Pupkin");
	teacher.age = 30;
	teacher.salary = 1523.99;
	fstream f1(FName, ios::binary | ios::out);
	f1.write((char*)&teacher, sizeof(teacher));
