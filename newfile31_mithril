int main()
{
	setlocale(LC_ALL, "Rus");
	vector<string> slova = { "ВОЗ","ЗОВ","ТОК","КОТ","ПАРА","АРАП","ТОРТ","ТОРГ"};
	queue <string> res;
	set <string> anagrams;

	for (int i = 0; i < slova.size(); i++)
	{
		string c = slova[i];
		for (int j = 0; j < c.size() - 1; j++)
		{
			for (int k = 0; k < c.size() -j- 1; k++)
			{
				if (c[k] > c[k + 1])
				{
					char tmpr = c[k];
					c[k] = c[k + 1];
					c[k + 1] = tmpr;
				}
			}
		}
		if (anagrams.find(c) == anagrams.end())
		{
			anagrams.insert(c);
			res.push(slova[i]);
		}
	}
	cout << "_____" << endl;;
	for (string keg : anagrams)
	{
		cout << keg << " ";
	}
	cout << endl;
	while (!res.empty())
	{
		cout << res.front() << " ";
		res.pop();
	}
	cout << endl;
}

