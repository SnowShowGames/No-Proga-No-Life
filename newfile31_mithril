string keysToWords(string word)
{
	for (int j = 0; j < word.size() - 1; j++)
	{
		for (int k = 0; k < word.size() - j - 1; k++)
		{
			if (word[k] > word[k + 1])
			{
				char tmpr = word[k];
				word[k] = word[k + 1];
				word[k + 1] = tmpr;
			}
		}
	}
	return word;
}
vector <string> findKeyForMyWord(vector<string> words)
{
	vector <string> kg;
	for (int i = 0; i < words.size(); i++)
	{
		string c = keysToWords(words[i]);

		bool f = 0;
		for (int j = 0; j < kg.size(); j++)
		{
			if (kg[j] == c)
			{
				f = 1;
			}
		}
		if (!f)
		{
			kg.push_back(c);
		}
	}
	return kg;
}
