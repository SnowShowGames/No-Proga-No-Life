//Во входном файле задан набор слов и целых чисел, разделенных пробелами. Найти все слова, встречающиеся столько же раз, сколько первое число.

//Анаграммы – это слова, у которых те же буквы в том же количестве, но они располагаются в другом порядке. Исключить из массива строк слова-анаграммы.
//через set, использовать в процессе size
int main()
{
	setlocale(LC_ALL, "RUS");
	//set <vector<char>> sen;
	set<string> sen;
	string slovo;

	while (cin >> slovo)
	{
		multiset <char> letters;
		//vector <char> letters;
		for (int i = 0; i < slovo.size(); i++)
		{
			letters.insert(slovo[i]);
		}
		string ar;
		for (multiset<char>::iterator it = letters.begin(); it != letters.end(); ++it)
		{
			ar.push_back(*it);
		}
		int before = sen.size();
		sen.insert(ar);
		int after = sen.size();
		if (after > before)
		{
			cout << slovo << " ";
		}
	}
	cout << endl;
	//сравниваем длину, и чтобы кол-во букв было одиноковым.
}
