bool Fibonaci(int n) //проверка на Фибоначчи
{
	if (n < 0) return 0;
	if (n == 0 || n == 1) return 1;
	int curr = 1;
	int last = 1;
	while (curr < n)
	{
		int nxt = curr;
		curr = last;
		last = nxt + last;
	}
	if (curr == n)
		return 1;

	return 0;
}

//максимальный лимит
int maxVector(vector <int> x)
{
	int max = x[0]; // та же история что и с minIndexVector
	for (auto i : x)
	{
		if (max < i) max = i;
	}
	return max;
}

//сумма вектора
int SumVector(vector <int> x)
{
	int sm = 0;
	for (auto i : x)
	{
		sm += i;
	}
	return sm;
}

