int minIndexVector(vector <int> x)
{
	int mn = x[0]; //x[0] это местный максимум, ни в коем случае не 0 и тем более не -1
	bool flag = 0;
	for (int i = 0; i < x.size(); i++)
	{
		if (Fibonaci(i))
		{
			if (x[i] < mn)
			{
				mn = x[i];
				flag = 1;
			}
		}
	}
	if (!flag) {
		cout << "???" << endl;
		return 0;
	}
	return mn;
}

